# Firebase Configuration
# Copy this file to .env and fill in your actual Firebase credentials
# NEVER commit your .env file to version control!

# Required Firebase Configuration
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id
REACT_APP_FIREBASE_MEASUREMENT_ID=your_measurement_id

# API Configuration
# For Vercel deployment: Use Render backend URL
REACT_APP_API_BASE=https://verceldepo.onrender.com

# For local development: Use localhost
# REACT_APP_API_BASE=http://localhost:5000

# Optional: Environment
REACT_APP_ENV=development

# How to get Firebase credentials:
# 1. Go to Firebase Console -> Project Settings -> General
# 2. Scroll down to "Firebase SDK snippet" section
# 3. Copy the configuration values
# 4. Replace the placeholder values above with your actual credentials

# SECURITY NOTES:
# - Never share these credentials publicly
# - Add .env to your .gitignore file
# - Use different credentials for development and production
# - Regenerate keys if they're ever compromised
